# 프론트엔드 .env 템플릿 — 이 파일을 .env.development로 복사한 뒤 실제 값으로 채우세요

# 개발 서버 포트
VITE_APP_PORT=3000

# 개발용 API 서버 주소
VITE_API_BASE_URL=http://localhost:8000/api

# 개발용 WebSocket 서버 주소
VITE_WEBSOCKET_URL=ws://localhost:8000

# Cesium Ion 액세스 토큰 (https://ion.cesium.com/tokens 에서 발급)
VITE_CESIUM_ION_TOKEN=토큰입력
